<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.latcn.a2a.permission.admin.mapper.DepartmentMapper">

    <resultMap id="BaseResultMap" type="io.github.latcn.a2a.permission.admin.entity.Department">
        <id column="id" property="id"/>
        <result column="dept_name" property="deptName"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByPathPrefix" resultMap="BaseResultMap">
        SELECT * FROM t_department WHERE path LIKE CONCAT(#{pathPrefix}, '%')
    </select>

</mapper>