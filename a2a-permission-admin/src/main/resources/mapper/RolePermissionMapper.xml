<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.latcn.a2a.permission.admin.infra.mapper.RolePermissionMapper">

    <resultMap id="BaseResultMap" type="io.github.latcn.a2a.permission.admin.domain.entity.RolePermission">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="permission_id" property="permissionId"/>
        <result column="effect" property="effect"/>
        <result column="row_rule_template" property="rowRuleTemplate"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByRoleIds" resultMap="BaseResultMap">
        SELECT * FROM t_role_permission WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </select>

    <select id="selectByRoleAndPermission" resultMap="BaseResultMap">
        SELECT * FROM t_role_permission
        WHERE role_id = #{roleId} AND permission_id = #{permissionId}
        LIMIT 1
    </select>

</mapper>