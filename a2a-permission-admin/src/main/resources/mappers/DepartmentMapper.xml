<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.latcn.a2a.permission.admin.infra.mapper.DepartmentMapper">

    <resultMap id="BaseResultMap" type="io.github.latcn.a2a.permission.admin.infrastructure.persistence.entity.DepartmentDO">
        <id column="id" property="id"/>
        <result column="dept_name" property="deptName"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByPathPrefix" resultMap="BaseResultMap">
        SELECT * FROM t_department WHERE path LIKE CONCAT(#{pathPrefix}, '%')
    </select>

    <select id="selectForUpdate" resultMap="BaseResultMap">
        SELECT * FROM t_department WHERE id = #{id} FOR UPDATE
    </select>

    <select id="selectSubDeptIdsByPath" resultType="java.lang.Long">
        SELECT id FROM t_department WHERE path LIKE CONCAT(#{path}, '/%')
    </select>

    <update id="batchCascadeUpdatePath">
        UPDATE t_department
        SET path = REPLACE(path, #{oldPrefix}, #{newPrefix})
        WHERE id IN
        <foreach collection="childIds" item="childId" open="(" separator="," close=")">
            #{childId}
        </foreach>
    </update>

    <update id="updateParentAndPath">
        UPDATE t_department
        SET parent_id = #{parentId}, path = #{path}, updated_at = CURRENT_TIMESTAMP(6)
        WHERE id = #{id}
    </update>

    <select id="selectPath" resultType="java.lang.String">
        SELECT path FROM t_department WHERE id = #{id}
    </select>

</mapper>